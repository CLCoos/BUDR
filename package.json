    "@supabase/supabase-js": "^2.100.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "lucide-react": "^1.7.0",
    "next": "15.1.11",
    "react": "19.0.3",
    "react-dom": "19.0.3",
    "recharts": "^2.15.2",
    "sonner": "^1.7.1"
  },
  "devDependencies": {
